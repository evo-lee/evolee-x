      "fontSize": 16,
      "fontFamily": 1,
      "text": "组装成统一的 JSON 结构：\n{\n  posts: [{ title, date, summary, keyPoints, url }],  // Top 12\n  tweets: [{ text, date, url, metrics }],             // Top 8\n  projects: [{ name, description, url }]              // Top 8\n}",
      "textAlign": "left",
